# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- LLM model tiers (optional; defaults shown) ---
# MODEL_SMALL=claude-haiku-4-5     # simple/mechanical prompts
# MODEL_MEDIUM=claude-sonnet-5     # most drafting/summarizing
# MODEL_LARGE=claude-opus-4-8      # hard reasoning-heavy sections

# --- LangSmith tracing (optional; leave unset to disable) ---
# LANGSMITH_API_KEY=ls-...
# LANGSMITH_PROJECT=ai-code-documentation

# --- Other (optional; defaults shown) ---
# JOBS_BASE_PATH=./temp/jobs
# MAX_UPLOAD_SIZE_MB=400
# MAX_RETRIES=3
